DATABASE_URL="postgresql://user:password@localhost:5432/vaultchat?schema=public"
OPENAI_API_KEY="sk-..."

# Chat response length & sampling (Responses API)
# CHAT_RESPONSE_STYLE=balanced   # concise | balanced (default) | detailed
# CHAT_TEMPERATURE=0.7             # 0–2
# CHAT_MAX_OUTPUT_TOKENS=2048      # upper cap on reply length
# CHAT_TOP_P=                     # optional, 0–1 (leave unset to omit)
# CHAT_REASONING_EFFORT=medium     # low | medium | high — o3, o4-mini only

# Tone overlay (appended to style prompt)
# AI_PERSONALITY=critical          # critical | neutral | supportive
